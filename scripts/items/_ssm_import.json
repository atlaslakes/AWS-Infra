{
  "commands": [
    "set -e",
    "B=frappe_docker-backend-1",
    "echo '=== BACKUP ==='; docker exec $B bench --site frontend backup 2>&1 | tail -3 || echo backup-warn",
    "echo '=== FETCH BUNDLE ==='; rm -rf /tmp/migrate /tmp/migrate.tgz; mkdir -p /tmp/migrate",
    "aws s3 cp s3://erpnext-prod-clean-20260617a-erpnextbucket-uy3oguk4cgy1/migrate/migrate.tgz /tmp/migrate.tgz --region us-east-1",
    "tar xzf /tmp/migrate.tgz -C /tmp/migrate",
    "echo  | base64 -d > /tmp/_import.py",
    "docker exec $B rm -rf /tmp/migrate; docker cp /tmp/migrate $B:/tmp/migrate; docker cp /tmp/_import.py $B:/tmp/_import.py",
    "echo '=== PHASE PRE ==='; docker exec $B bash -lc 'cd /home/frappe/frappe-bench/sites && ../env/bin/python /tmp/_import.py pre'",
    "echo '=== MIGRATE ==='; docker exec $B bench --site frontend migrate 2>&1 | tail -15",
    "echo '=== PHASE POST ==='; docker exec $B bash -lc 'cd /home/frappe/frappe-bench/sites && ../env/bin/python /tmp/_import.py post'",
    "echo '=== CLEAR CACHE ==='; docker exec $B bench --site frontend clear-cache; docker exec $B bench --site frontend clear-website-cache",
    "echo ALL_DONE"
  ]
}
