{
  "commands": [
    "set -e",
    "echo  | base64 -d > /tmp/_export.py",
    "B=frappe_docker-backend-1",
    "docker exec $B rm -rf /tmp/migrate; docker cp /tmp/_export.py $B:/tmp/_export.py",
    "docker exec $B bash -lc 'cd /home/frappe/frappe-bench/sites && ../env/bin/python /tmp/_export.py'",
    "docker exec $B bash -lc 'cd /tmp/migrate && tar czf /tmp/migrate.tgz .'",
    "docker cp $B:/tmp/migrate.tgz /tmp/migrate.tgz",
    "ls -la /tmp/migrate.tgz",
    "aws s3 cp /tmp/migrate.tgz s3://erpnext-poc-erpnextbucket-780m8mqa8l0v/migrate/migrate.tgz --region us-east-1",
    "echo UPLOADED_OK"
  ]
}
