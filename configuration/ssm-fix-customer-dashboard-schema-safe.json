{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/fix_customer_dashboard_schema_safe.py <<'PY'",
      "import frappe",
      "",
      "ROLE = 'Customer'",
      "TARGET_WS = 'Customer Dashboard'",
      "FALLBACK_WS = 'Customer Self-Service'",
      "MODULE_PROFILE = 'Customer Minimal Modules'",
      "",
      "def existing_columns(table_name):",
      "    rows = frappe.db.sql(f\"SHOW COLUMNS FROM `{table_name}`\", as_dict=True)",
      "    return {r.get('Field') for r in rows}",
      "",
      "def resolve_workspace():",
      "    if frappe.db.exists('Workspace', TARGET_WS):",
      "        return TARGET_WS",
      "    if frappe.db.exists('Workspace', FALLBACK_WS):",
      "        return FALLBACK_WS",
      "    return None",
      "",
      "def run():",
      "    cols = existing_columns('tabWorkspace')",
      "    print('tabWorkspace columns:', ', '.join(sorted(cols)))",
      "",
      "    ws_name = resolve_workspace()",
      "    if not ws_name:",
      "        print('No customer workspace found')",
      "        return",
      "",
      "    print('Using workspace:', ws_name)",
      "",
      "    # Apply only columns that exist in this build.",
      "    if 'title' in cols:",
      "        frappe.db.set_value('Workspace', ws_name, 'title', TARGET_WS, update_modified=False)",
      "    if 'label' in cols:",
      "        frappe.db.set_value('Workspace', ws_name, 'label', TARGET_WS, update_modified=False)",
      "    if 'public' in cols:",
      "        frappe.db.set_value('Workspace', ws_name, 'public', 0, update_modified=False)",
      "    if 'is_hidden' in cols:",
      "        frappe.db.set_value('Workspace', ws_name, 'is_hidden', 0, update_modified=False)",
      "",
      "    # Customer-only role scope on workspace.",
      "    frappe.db.delete('Has Role', {'parenttype': 'Workspace', 'parent': ws_name})",
      "    if not frappe.db.exists('Has Role', {'parenttype': 'Workspace', 'parent': ws_name, 'role': ROLE}):",
      "        frappe.get_doc({'doctype': 'Has Role', 'parent': ws_name, 'parenttype': 'Workspace', 'parentfield': 'roles', 'role': ROLE}).insert(ignore_permissions=True)",
      "",
      "    # Assign customer users to this exact workspace record.",
      "    users = sorted(set([",
      "        r.get('parent')",
      "        for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})",
      "        if r.get('parent') and r.get('parent') != 'Guest'",
      "    ]))",
      "    for uid in users:",
      "        frappe.db.set_value('User', uid, 'default_workspace', ws_name, update_modified=False)",
      "        frappe.db.set_value('User', uid, 'module_profile', MODULE_PROFILE, update_modified=False)",
      "",
      "    frappe.db.commit()",
      "",
      "    print('Customer users assigned to workspace:', ws_name)",
      "    for uid in users:",
      "        u = frappe.get_doc('User', uid)",
      "        print(f\"- {uid} | default_workspace={u.default_workspace} | module_profile={u.module_profile}\")",
      "PY",
      "docker cp /tmp/fix_customer_dashboard_schema_safe.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_schema_safe.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_fix_customer_dashboard_schema_safe.run'",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend clear-cache && bench --site frontend clear-website-cache'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_schema_safe.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_inspect_customer_workspace_routes.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_route_v2.py'"
    ]
  }
}
