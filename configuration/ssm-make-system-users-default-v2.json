{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/make_system_users_default_v2.py <<'PY'",
      "import frappe",
      "",
      "def set_future_default_via_docfield():",
      "    df_name = frappe.db.get_value('DocField', {'parent': 'User', 'fieldname': 'user_type'}, 'name')",
      "    if not df_name:",
      "        print('DocField User.user_type not found; future default not changed')",
      "        return 'not-found'",
      "    df = frappe.get_doc('DocField', df_name)",
      "    df.default = 'System User'",
      "    df.save(ignore_permissions=True)",
      "    print('Set DocField default: User.user_type -> System User')",
      "    return 'applied'",
      "",
      "def run():",
      "    users = frappe.get_all('User', fields=['name', 'user_type'])",
      "    total = len(users)",
      "    before_system = sum(1 for u in users if u.get('user_type') == 'System User')",
      "    before_website = sum(1 for u in users if u.get('user_type') == 'Website User')",
      "",
      "    changed = 0",
      "    skipped = []",
      "    for u in users:",
      "        name = u['name']",
      "        if name in ('Guest', 'Administrator'):",
      "            skipped.append(name)",
      "            continue",
      "        if u.get('user_type') != 'System User':",
      "            user = frappe.get_doc('User', name)",
      "            user.user_type = 'System User'",
      "            user.save(ignore_permissions=True)",
      "            changed += 1",
      "",
      "    future_default_status = set_future_default_via_docfield()",
      "    frappe.db.commit()",
      "",
      "    users_after = frappe.get_all('User', fields=['name', 'user_type'])",
      "    after_system = sum(1 for u in users_after if u.get('user_type') == 'System User')",
      "    after_website = sum(1 for u in users_after if u.get('user_type') == 'Website User')",
      "",
      "    print('Total users:', total)",
      "    print('Before System User:', before_system)",
      "    print('Before Website User:', before_website)",
      "    print('Changed to System User:', changed)",
      "    print('Skipped:', ', '.join(skipped) if skipped else '(none)')",
      "    print('After System User:', after_system)",
      "    print('After Website User:', after_website)",
      "    print('Future default status:', future_default_status)",
      "PY",
      "docker cp /tmp/make_system_users_default_v2.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_make_system_users_default_v2.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_make_system_users_default_v2.run'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_make_system_users_default_v2.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_make_system_users_default.py'"
    ]
  }
}
