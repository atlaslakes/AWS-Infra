{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "echo '=== Backup before purge ==='",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend backup --with-files'",
      "cat > /tmp/purge_erpnext_business_data.py <<'PY'",
      "import frappe",
      "",
      "def c(dt):",
      "    return frappe.db.count(dt)",
      "",
      "frappe.init(site='frontend')",
      "frappe.connect()",
      "",
      "print('=== Pre-counts ===')",
      "for dt in ['Customer', 'Item', 'Sales Invoice', 'Sales Order', 'Quotation', 'Delivery Note']:",
      "    print(f'{dt}: {c(dt)}')",
      "print(f'User: {c(\"User\")}')",
      "",
      "frappe.db.delete('Sales Invoice Item')",
      "frappe.db.delete('Sales Order Item')",
      "frappe.db.delete('Delivery Note Item')",
      "frappe.db.delete('Quotation Item')",
      "frappe.db.delete('Payment Entry Reference')",
      "frappe.db.delete('Sales Taxes and Charges', {'parenttype': ('in', ['Sales Invoice', 'Sales Order', 'Delivery Note', 'Quotation'])})",
      "frappe.db.delete('Sales Team', {'parenttype': ('in', ['Sales Invoice', 'Sales Order', 'Delivery Note', 'Quotation'])})",
      "frappe.db.delete('Payment Schedule', {'parenttype': ('in', ['Sales Invoice', 'Sales Order', 'Quotation'])})",
      "frappe.db.delete('Packed Item', {'parenttype': ('in', ['Sales Invoice', 'Sales Order', 'Delivery Note', 'Quotation'])})",
      "frappe.db.delete('GL Entry', {'voucher_type': ('in', ['Sales Invoice', 'Sales Order', 'Delivery Note', 'Quotation', 'Payment Entry'])})",
      "",
      "frappe.db.delete('POS Invoice')",
      "frappe.db.delete('Sales Invoice')",
      "frappe.db.delete('Delivery Note')",
      "frappe.db.delete('Sales Order')",
      "frappe.db.delete('Quotation')",
      "frappe.db.delete('Payment Entry')",
      "",
      "frappe.db.delete('Customer Credit Limit')",
      "frappe.db.delete('Dynamic Link', {'link_doctype': 'Customer'})",
      "frappe.db.delete('Customer')",
      "",
      "frappe.db.delete('Item Barcode')",
      "frappe.db.delete('UOM Conversion Detail', {'parenttype': 'Item'})",
      "frappe.db.delete('Item Default')",
      "frappe.db.delete('Item Tax')",
      "frappe.db.delete('Item Supplier')",
      "frappe.db.delete('Item Reorder')",
      "frappe.db.delete('Item Price')",
      "frappe.db.delete('Serial No')",
      "frappe.db.delete('Batch')",
      "frappe.db.delete('Stock Ledger Entry')",
      "frappe.db.delete('Bin')",
      "frappe.db.delete('Item')",
      "",
      "frappe.db.commit()",
      "",
      "print('=== Post-counts ===')",
      "for dt in ['Customer', 'Item', 'Sales Invoice', 'Sales Order', 'Quotation', 'Delivery Note']:",
      "    print(f'{dt}: {c(dt)}')",
      "print(f'User: {c(\"User\")}')",
      "",
      "frappe.destroy()",
      "PY",
      "docker cp /tmp/purge_erpnext_business_data.py frappe_docker-backend-1:/tmp/purge_erpnext_business_data.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'python3 /tmp/purge_erpnext_business_data.py'",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend clear-cache && bench --site frontend clear-website-cache'"
    ]
  }
}
