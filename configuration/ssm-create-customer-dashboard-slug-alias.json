{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/create_customer_dashboard_slug_alias.py <<'PY'",
      "import frappe",
      "",
      "ROLE = 'Customer'",
      "ALIAS_NAME = 'customer-dashboard'",
      "ALIAS_TITLE = 'Customer Dashboard'",
      "SOURCE_WS = 'Customer Dashboard'",
      "MODULE_PROFILE = 'Customer Minimal Modules'",
      "",
      "def ensure_alias_workspace():",
      "    if frappe.db.exists('Workspace', ALIAS_NAME):",
      "        print('Alias workspace exists:', ALIAS_NAME)",
      "        return ALIAS_NAME",
      "",
      "    src = frappe.get_doc('Workspace', SOURCE_WS) if frappe.db.exists('Workspace', SOURCE_WS) else None",
      "",
      "    # Use a slug title so this build stores a matching workspace route/name behavior.",
      "    payload = {",
      "        'doctype': 'Workspace',",
      "        'title': ALIAS_NAME,",
      "        'label': ALIAS_TITLE,",
      "        'module': (src.module if src else 'Selling'),",
      "        'public': 0,",
      "        'is_hidden': 0,",
      "        'icon': (src.icon if src else 'users'),",
      "        'indicator_color': (src.indicator_color if src else 'blue'),",
      "        'content': (src.content if src else '[]')",
      "    }",
      "    doc = frappe.get_doc(payload).insert(ignore_permissions=True)",
      "    print('Alias workspace created with name:', doc.name)",
      "    return doc.name",
      "",
      "def lock_workspace_to_customer(ws_name):",
      "    frappe.db.delete('Has Role', {'parenttype': 'Workspace', 'parent': ws_name})",
      "    frappe.get_doc({",
      "        'doctype': 'Has Role',",
      "        'parent': ws_name,",
      "        'parenttype': 'Workspace',",
      "        'parentfield': 'roles',",
      "        'role': ROLE",
      "    }).insert(ignore_permissions=True)",
      "    frappe.db.set_value('Workspace', ws_name, 'public', 0, update_modified=False)",
      "    print('Workspace role scope set to Customer:', ws_name)",
      "",
      "def assign_customer_users(ws_name):",
      "    users = sorted(set([",
      "        r.get('parent')",
      "        for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})",
      "        if r.get('parent') and r.get('parent') != 'Guest'",
      "    ]))",
      "    for uid in users:",
      "        frappe.db.set_value('User', uid, 'default_workspace', ws_name, update_modified=False)",
      "        frappe.db.set_value('User', uid, 'module_profile', MODULE_PROFILE, update_modified=False)",
      "    print('Customer users assigned to', ws_name)",
      "    for uid in users:",
      "        print('-', uid)",
      "",
      "def run():",
      "    ws_name = ensure_alias_workspace()",
      "    lock_workspace_to_customer(ws_name)",
      "    assign_customer_users(ws_name)",
      "    frappe.db.commit()",
      "    print('Workspace check exists(customer-dashboard):', bool(frappe.db.exists('Workspace', 'customer-dashboard')))",
      "PY",
      "docker cp /tmp/create_customer_dashboard_slug_alias.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_create_customer_dashboard_slug_alias.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_create_customer_dashboard_slug_alias.run'",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend clear-cache && bench --site frontend clear-website-cache'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_create_customer_dashboard_slug_alias.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_diagnose_customer_dashboard_route.py'"
    ]
  }
}
