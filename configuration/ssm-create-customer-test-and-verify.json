{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/create_customer_test_and_verify.py <<'PY'",
      "import frappe",
      "",
      "TEST_USER = 'customer.test@atlaslakes.com'",
      "TEST_FULL_NAME = 'Customer Test'",
      "TEST_PASSWORD = 'Temp@12345'",
      "CUSTOMER_ROLE = 'Customer'",
      "WORKSPACE = 'Customer Dashboard'",
      "WORKSPACE_TITLE_SLUG = 'customer-dashboard'",
      "MODULE_PROFILE = 'Customer Minimal Modules'",
      "",
      "def ensure_workspace():",
      "    if not frappe.db.exists('Workspace', WORKSPACE):",
      "        frappe.throw(f'Workspace missing: {WORKSPACE}')",
      "",
      "    frappe.db.set_value('Workspace', WORKSPACE, 'title', WORKSPACE_TITLE_SLUG, update_modified=False)",
      "    frappe.db.set_value('Workspace', WORKSPACE, 'label', WORKSPACE, update_modified=False)",
      "    frappe.db.set_value('Workspace', WORKSPACE, 'public', 0, update_modified=False)",
      "    frappe.db.set_value('Workspace', WORKSPACE, 'is_hidden', 0, update_modified=False)",
      "",
      "    frappe.db.delete('Has Role', {'parenttype': 'Workspace', 'parent': WORKSPACE})",
      "    frappe.get_doc({",
      "        'doctype': 'Has Role',",
      "        'parent': WORKSPACE,",
      "        'parenttype': 'Workspace',",
      "        'parentfield': 'roles',",
      "        'role': CUSTOMER_ROLE",
      "    }).insert(ignore_permissions=True)",
      "",
      "def ensure_test_user():",
      "    if frappe.db.exists('User', TEST_USER):",
      "        user = frappe.get_doc('User', TEST_USER)",
      "        print('Test user exists:', TEST_USER)",
      "    else:",
      "        user = frappe.get_doc({",
      "            'doctype': 'User',",
      "            'email': TEST_USER,",
      "            'first_name': TEST_FULL_NAME,",
      "            'enabled': 1,",
      "            'send_welcome_email': 0,",
      "            'user_type': 'System User'",
      "        })",
      "        user.insert(ignore_permissions=True)",
      "        print('Test user created:', TEST_USER)",
      "",
      "    # Hard-set password for immediate login testing.",
      "    user.new_password = TEST_PASSWORD",
      "    user.enabled = 1",
      "    user.user_type = 'System User'",
      "    user.default_workspace = WORKSPACE",
      "    user.module_profile = MODULE_PROFILE",
      "    user.home_page = ''",
      "    user.save(ignore_permissions=True)",
      "",
      "    # Keep only Customer role on test user for strict simulation.",
      "    frappe.db.delete('Has Role', {'parenttype': 'User', 'parent': TEST_USER})",
      "    frappe.get_doc({",
      "        'doctype': 'Has Role',",
      "        'parent': TEST_USER,",
      "        'parenttype': 'User',",
      "        'parentfield': 'roles',",
      "        'role': CUSTOMER_ROLE",
      "    }).insert(ignore_permissions=True)",
      "",
      "def verify():",
      "    ws = frappe.get_doc('Workspace', WORKSPACE)",
      "    ws_roles = [r.role for r in (ws.roles or [])]",
      "    user = frappe.get_doc('User', TEST_USER)",
      "    user_roles = [r.role for r in (user.roles or [])]",
      "",
      "    print('--- Verification ---')",
      "    print('Workspace name:', WORKSPACE)",
      "    print('Workspace title:', ws.title)",
      "    print('Workspace label:', ws.label)",
      "    print('Workspace roles:', ', '.join(ws_roles) if ws_roles else '(none)')",
      "    print('Test user:', user.name)",
      "    print('User type:', user.user_type)",
      "    print('Default workspace:', user.default_workspace)",
      "    print('Module profile:', user.module_profile)",
      "    print('User roles:', ', '.join(user_roles) if user_roles else '(none)')",
      "    print('Expected app route: /app/customer-dashboard')",
      "",
      "def run():",
      "    ensure_workspace()",
      "    ensure_test_user()",
      "    frappe.db.commit()",
      "    verify()",
      "PY",
      "docker cp /tmp/create_customer_test_and_verify.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_create_customer_test_and_verify.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_create_customer_test_and_verify.run'",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend clear-cache && bench --site frontend clear-website-cache'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_create_customer_test_and_verify.py'"
    ]
  }
}
