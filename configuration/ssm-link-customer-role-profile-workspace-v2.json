{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/link_customer_profile_workspace_v2.py <<'PY'",
      "import frappe",
      "",
      "WORKSPACE = 'Customer Self-Service'",
      "ROLE = 'Customer'",
      "ROLE_PROFILE = 'Customer Role Profile'",
      "",
      "def ensure_role_profile():",
      "    if not frappe.db.exists('Role Profile', ROLE_PROFILE):",
      "        doc = frappe.get_doc({'doctype': 'Role Profile', 'role_profile': ROLE_PROFILE})",
      "        doc.insert(ignore_permissions=True)",
      "        print(f'Role Profile created: {ROLE_PROFILE}')",
      "    else:",
      "        print(f'Role Profile exists: {ROLE_PROFILE}')",
      "",
      "def ensure_has_role(parent, parenttype):",
      "    exists = frappe.db.exists('Has Role', {",
      "        'parent': parent,",
      "        'parenttype': parenttype,",
      "        'parentfield': 'roles',",
      "        'role': ROLE,",
      "    })",
      "    if exists:",
      "        print(f'Already linked: {parenttype} {parent} -> {ROLE}')",
      "        return",
      "",
      "    row = frappe.get_doc({",
      "        'doctype': 'Has Role',",
      "        'parent': parent,",
      "        'parenttype': parenttype,",
      "        'parentfield': 'roles',",
      "        'role': ROLE,",
      "    })",
      "    row.insert(ignore_permissions=True)",
      "    print(f'Linked: {parenttype} {parent} -> {ROLE}')",
      "",
      "def run():",
      "    ensure_role_profile()",
      "    ensure_has_role(ROLE_PROFILE, 'Role Profile')",
      "    ensure_has_role(WORKSPACE, 'Workspace')",
      "    frappe.db.commit()",
      "",
      "    print('Verification:')",
      "    rp_ok = bool(frappe.db.exists('Has Role', {'parent': ROLE_PROFILE, 'parenttype': 'Role Profile', 'parentfield': 'roles', 'role': ROLE}))",
      "    ws_ok = bool(frappe.db.exists('Has Role', {'parent': WORKSPACE, 'parenttype': 'Workspace', 'parentfield': 'roles', 'role': ROLE}))",
      "    print('Customer in Role Profile:', rp_ok)",
      "    print('Customer linked to Workspace:', ws_ok)",
      "PY",
      "docker cp /tmp/link_customer_profile_workspace_v2.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_link_customer_profile_workspace_v2.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_link_customer_profile_workspace_v2.run'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_link_customer_profile_workspace_v2.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_link_customer_profile_workspace.py'"
    ]
  }
}
