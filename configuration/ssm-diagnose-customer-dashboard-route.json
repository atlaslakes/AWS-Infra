{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/diagnose_customer_dashboard_route.py <<'PY'",
      "import frappe",
      "",
      "def run():",
      "    print('=== Workspaces with customer in name/title/label ===')",
      "    rows = frappe.db.sql(\"\"\"",
      "        SELECT name, title, label, module, public, is_hidden",
      "        FROM `tabWorkspace`",
      "        WHERE LOWER(name) LIKE '%customer%'",
      "           OR LOWER(IFNULL(title,'')) LIKE '%customer%'",
      "           OR LOWER(IFNULL(label,'')) LIKE '%customer%'",
      "        ORDER BY name",
      "    \"\"\", as_dict=True)",
      "    for r in rows:",
      "        print(f\"- {r['name']} | title={r.get('title')} | label={r.get('label')} | module={r.get('module')}\")",
      "",
      "    print('=== Users with Customer role ===')",
      "    users = frappe.db.sql(\"\"\"",
      "        SELECT DISTINCT hr.parent AS user_id, u.default_workspace, u.home_page, u.module_profile",
      "        FROM `tabHas Role` hr",
      "        JOIN `tabUser` u ON u.name = hr.parent",
      "        WHERE hr.parenttype='User' AND hr.role='Customer' AND hr.parent != 'Guest'",
      "        ORDER BY hr.parent",
      "    \"\"\", as_dict=True)",
      "    for u in users:",
      "        print(f\"- {u['user_id']} | default_workspace={u.get('default_workspace')} | home_page={u.get('home_page')} | module_profile={u.get('module_profile')}\")",
      "",
      "    print('=== Default values containing customer-dashboard ===')",
      "    dv = frappe.db.sql(\"\"\"",
      "        SELECT parent, defkey, defvalue",
      "        FROM `tabDefaultValue`",
      "        WHERE LOWER(IFNULL(defvalue,'')) LIKE '%customer-dashboard%'",
      "           OR LOWER(IFNULL(defkey,'')) LIKE '%customer-dashboard%'",
      "        ORDER BY parent, defkey",
      "    \"\"\", as_dict=True)",
      "    for r in dv:",
      "        print(f\"- parent={r.get('parent')} | {r.get('defkey')}={r.get('defvalue')}\")",
      "",
      "    print('=== User records containing customer-dashboard ===')",
      "    ur = frappe.db.sql(\"\"\"",
      "        SELECT name, default_workspace, home_page",
      "        FROM `tabUser`",
      "        WHERE LOWER(IFNULL(default_workspace,'')) LIKE '%customer-dashboard%'",
      "           OR LOWER(IFNULL(home_page,'')) LIKE '%customer-dashboard%'",
      "        ORDER BY name",
      "    \"\"\", as_dict=True)",
      "    for r in ur:",
      "        print(f\"- {r.get('name')} | default_workspace={r.get('default_workspace')} | home_page={r.get('home_page')}\")",
      "PY",
      "docker cp /tmp/diagnose_customer_dashboard_route.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_diagnose_customer_dashboard_route.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_diagnose_customer_dashboard_route.run'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_diagnose_customer_dashboard_route.py'"
    ]
  }
}
