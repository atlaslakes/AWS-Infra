{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/fix_customer_dashboard_route.py <<'PY'",
      "import frappe",
      "",
      "ROLE = 'Customer'",
      "TARGET_NAME = 'customer-dashboard'",
      "TARGET_TITLE = 'Customer Dashboard'",
      "SOURCE_CANDIDATES = ['Customer Dashboard', 'Customer Self-Service']",
      "",
      "def get_source_workspace():",
      "    for name in SOURCE_CANDIDATES:",
      "        if frappe.db.exists('Workspace', name):",
      "            return frappe.get_doc('Workspace', name)",
      "    return None",
      "",
      "def ensure_target_workspace():",
      "    if frappe.db.exists('Workspace', TARGET_NAME):",
      "        ws = frappe.get_doc('Workspace', TARGET_NAME)",
      "        print('Workspace exists:', TARGET_NAME)",
      "    else:",
      "        src = get_source_workspace()",
      "        payload = {",
      "            'doctype': 'Workspace',",
      "            'name': TARGET_NAME,",
      "            'title': TARGET_TITLE,",
      "            'label': TARGET_TITLE,",
      "            'module': (src.module if src else 'Selling'),",
      "            'public': 0,",
      "            'is_hidden': 0,",
      "            'icon': (src.icon if src else 'users'),",
      "            'indicator_color': (src.indicator_color if src else 'blue'),",
      "            'content': (src.content if src else '[]')",
      "        }",
      "        ws = frappe.get_doc(payload).insert(ignore_permissions=True)",
      "        print('Workspace created:', TARGET_NAME)",
      "",
      "    # Normalize fields",
      "    ws.title = TARGET_TITLE",
      "    ws.label = TARGET_TITLE",
      "    ws.public = 0",
      "    ws.is_hidden = 0",
      "    ws.save(ignore_permissions=True)",
      "",
      "    # Force only Customer role access",
      "    frappe.db.delete('Has Role', {'parenttype': 'Workspace', 'parent': TARGET_NAME})",
      "    frappe.get_doc({",
      "        'doctype': 'Has Role',",
      "        'parent': TARGET_NAME,",
      "        'parenttype': 'Workspace',",
      "        'parentfield': 'roles',",
      "        'role': ROLE",
      "    }).insert(ignore_permissions=True)",
      "",
      "def assign_customer_users():",
      "    users = sorted(set([",
      "        r.get('parent')",
      "        for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})",
      "        if r.get('parent') and r.get('parent') != 'Guest'",
      "    ]))",
      "",
      "    for uid in users:",
      "        frappe.db.set_value('User', uid, 'default_workspace', TARGET_NAME, update_modified=False)",
      "    print('Customer users default workspace set:', TARGET_NAME)",
      "    for uid in users:",
      "        print('-', uid)",
      "",
      "def run():",
      "    ensure_target_workspace()",
      "    assign_customer_users()",
      "    frappe.db.commit()",
      "    print('Verification workspace exists:', bool(frappe.db.exists('Workspace', TARGET_NAME)))",
      "PY",
      "docker cp /tmp/fix_customer_dashboard_route.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_route.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_fix_customer_dashboard_route.run'",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend clear-cache && bench --site frontend clear-website-cache'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_route.py'"
    ]
  }
}
