{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/fix_customer_page_permission.py <<'PY'",
      "import frappe",
      "",
      "ROLE = 'Customer'",
      "",
      "def ensure_perm(doctype):",
      "    existing = frappe.db.exists('Custom DocPerm', {'parent': doctype, 'role': ROLE, 'permlevel': 0})",
      "    if existing:",
      "        d = frappe.get_doc('Custom DocPerm', existing)",
      "        d.read = 1",
      "        d.write = 0",
      "        d.create = 0",
      "        d.delete = 0",
      "        d.submit = 0",
      "        d.cancel = 0",
      "        d.amend = 0",
      "        d.save(ignore_permissions=True)",
      "        print(f'Updated permission: {doctype} -> {ROLE} read=1')",
      "        return",
      "",
      "    doc = frappe.get_doc({",
      "        'doctype': 'Custom DocPerm',",
      "        'parent': doctype,",
      "        'parenttype': 'DocType',",
      "        'parentfield': 'permissions',",
      "        'role': ROLE,",
      "        'permlevel': 0,",
      "        'read': 1,",
      "        'write': 0,",
      "        'create': 0,",
      "        'delete': 0,",
      "        'submit': 0,",
      "        'cancel': 0,",
      "        'amend': 0",
      "    })",
      "    doc.insert(ignore_permissions=True)",
      "    print(f'Created permission: {doctype} -> {ROLE} read=1')",
      "",
      "def run():",
      "    ensure_perm('Page')",
      "    ensure_perm('Workspace')",
      "    frappe.db.commit()",
      "    print('Done')",
      "PY",
      "docker cp /tmp/fix_customer_page_permission.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_page_permission.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_fix_customer_page_permission.run'",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend clear-cache && bench --site frontend clear-website-cache'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_page_permission.py'"
    ]
  }
}
