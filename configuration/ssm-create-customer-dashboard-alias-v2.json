{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/create_customer_dashboard_alias_v2.py <<'PY'",
      "import frappe",
      "",
      "SOURCE_WS = 'Customer Self-Service'",
      "TARGET_WS = 'Customer Dashboard'",
      "ROLE = 'Customer'",
      "MODULE_PROFILE = 'Customer Dashboard Only'",
      "",
      "def ensure_workspace_exists():",
      "    if frappe.db.exists('Workspace', TARGET_WS):",
      "        print('Workspace exists:', TARGET_WS)",
      "        return",
      "",
      "    src = frappe.get_doc('Workspace', SOURCE_WS)",
      "    payload = {",
      "        'doctype': 'Workspace',",
      "        'name': TARGET_WS,",
      "        'title': TARGET_WS,",
      "        'label': TARGET_WS,",
      "        'module': src.module or 'Selling',",
      "        'public': 0,",
      "        'is_hidden': 0,",
      "        'icon': src.icon or 'users',",
      "        'indicator_color': src.indicator_color or 'blue',",
      "        'content': src.content or '[]',",
      "    }",
      "    frappe.get_doc(payload).insert(ignore_permissions=True)",
      "    print('Workspace created:', TARGET_WS)",
      "",
      "def ensure_workspace_customer_role_only():",
      "    frappe.db.delete('Has Role', {'parenttype': 'Workspace', 'parent': TARGET_WS})",
      "    frappe.get_doc({",
      "        'doctype': 'Has Role',",
      "        'parent': TARGET_WS,",
      "        'parenttype': 'Workspace',",
      "        'parentfield': 'roles',",
      "        'role': ROLE,",
      "    }).insert(ignore_permissions=True)",
      "    frappe.db.set_value('Workspace', TARGET_WS, 'public', 0, update_modified=False)",
      "    frappe.db.set_value('Workspace', TARGET_WS, 'label', TARGET_WS, update_modified=False)",
      "    frappe.db.set_value('Workspace', TARGET_WS, 'title', TARGET_WS, update_modified=False)",
      "    print('Workspace role scope set to Customer only')",
      "",
      "def assign_customer_users():",
      "    customer_users = sorted(set([",
      "        r.get('parent')",
      "        for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})",
      "        if r.get('parent') and r.get('parent') != 'Guest'",
      "    ]))",
      "    for uid in customer_users:",
      "        frappe.db.set_value('User', uid, 'default_workspace', TARGET_WS, update_modified=False)",
      "        frappe.db.set_value('User', uid, 'module_profile', MODULE_PROFILE, update_modified=False)",
      "    print('Customer users assigned:', len(customer_users))",
      "    for uid in customer_users:",
      "        print(f'- {uid}')",
      "",
      "def run():",
      "    ensure_workspace_exists()",
      "    ensure_workspace_customer_role_only()",
      "    assign_customer_users()",
      "    frappe.db.commit()",
      "    print('Verification workspace exists:', bool(frappe.db.exists('Workspace', TARGET_WS)))",
      "PY",
      "docker cp /tmp/create_customer_dashboard_alias_v2.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_create_customer_dashboard_alias_v2.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_create_customer_dashboard_alias_v2.run'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_create_customer_dashboard_alias_v2.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_create_customer_dashboard_alias.py'"
    ]
  }
}
