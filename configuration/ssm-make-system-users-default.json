{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/make_system_users_default.py <<'PY'",
      "import frappe",
      "",
      "def ensure_before_insert_server_script():",
      "    name = 'Force System User Default'",
      "    script_body = \"if not doc.user_type:\n    doc.user_type = 'System User'\nelse:\n    doc.user_type = 'System User'\"",
      "",
      "    if frappe.db.exists('Server Script', name):",
      "        ss = frappe.get_doc('Server Script', name)",
      "        ss.script_type = 'DocType Event'",
      "        ss.reference_doctype = 'User'",
      "        ss.doctype_event = 'Before Insert'",
      "        ss.enabled = 1",
      "        ss.script = script_body",
      "        ss.save(ignore_permissions=True)",
      "        print('Server Script updated:', name)",
      "        return",
      "",
      "    ss = frappe.get_doc({",
      "        'doctype': 'Server Script',",
      "        'name': name,",
      "        'script_type': 'DocType Event',",
      "        'reference_doctype': 'User',",
      "        'doctype_event': 'Before Insert',",
      "        'enabled': 1,",
      "        'script': script_body,",
      "    })",
      "    ss.insert(ignore_permissions=True)",
      "    print('Server Script created:', name)",
      "",
      "def run():",
      "    users = frappe.get_all('User', fields=['name', 'user_type', 'enabled'])",
      "    total = len(users)",
      "    before_system = sum(1 for u in users if u.get('user_type') == 'System User')",
      "    before_website = sum(1 for u in users if u.get('user_type') == 'Website User')",
      "",
      "    changed = 0",
      "    skipped = []",
      "    for u in users:",
      "        name = u['name']",
      "        if name in ('Guest', 'Administrator'):",
      "            skipped.append(name)",
      "            continue",
      "        if u.get('user_type') != 'System User':",
      "            user = frappe.get_doc('User', name)",
      "            user.user_type = 'System User'",
      "            user.save(ignore_permissions=True)",
      "            changed += 1",
      "",
      "    server_script_status = 'not-applied'",
      "    try:",
      "        ensure_before_insert_server_script()",
      "        server_script_status = 'applied'",
      "    except Exception as exc:",
      "        server_script_status = f'failed: {exc}'",
      "",
      "    frappe.db.commit()",
      "",
      "    users_after = frappe.get_all('User', fields=['name', 'user_type'])",
      "    after_system = sum(1 for u in users_after if u.get('user_type') == 'System User')",
      "    after_website = sum(1 for u in users_after if u.get('user_type') == 'Website User')",
      "",
      "    print('Total users:', total)",
      "    print('Before System User:', before_system)",
      "    print('Before Website User:', before_website)",
      "    print('Changed to System User:', changed)",
      "    print('Skipped:', ', '.join(skipped) if skipped else '(none)')",
      "    print('After System User:', after_system)",
      "    print('After Website User:', after_website)",
      "    print('Future default enforcement (Server Script):', server_script_status)",
      "PY",
      "docker cp /tmp/make_system_users_default.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_make_system_users_default.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_make_system_users_default.run'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_make_system_users_default.py'"
    ]
  }
}
