{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/fix_customer_dashboard_slug_title.py <<'PY'",
      "import frappe",
      "",
      "ROLE = 'Customer'",
      "WS = 'Customer Dashboard'",
      "SLUG_TITLE = 'customer-dashboard'",
      "VISIBLE_LABEL = 'Customer Dashboard'",
      "",
      "def run():",
      "    if not frappe.db.exists('Workspace', WS):",
      "        frappe.throw(f'Workspace not found: {WS}')",
      "",
      "    # Route compatibility for builds that resolve workspace by slug(title).",
      "    frappe.db.set_value('Workspace', WS, 'title', SLUG_TITLE, update_modified=False)",
      "    frappe.db.set_value('Workspace', WS, 'label', VISIBLE_LABEL, update_modified=False)",
      "    frappe.db.set_value('Workspace', WS, 'public', 0, update_modified=False)",
      "    frappe.db.set_value('Workspace', WS, 'is_hidden', 0, update_modified=False)",
      "",
      "    # Scope workspace to Customer role only.",
      "    frappe.db.delete('Has Role', {'parenttype': 'Workspace', 'parent': WS})",
      "    frappe.get_doc({'doctype': 'Has Role', 'parent': WS, 'parenttype': 'Workspace', 'parentfield': 'roles', 'role': ROLE}).insert(ignore_permissions=True)",
      "",
      "    # Assign customer users to this workspace.",
      "    users = sorted(set([",
      "        r.get('parent')",
      "        for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})",
      "        if r.get('parent') and r.get('parent') != 'Guest'",
      "    ]))",
      "    for uid in users:",
      "        frappe.db.set_value('User', uid, 'default_workspace', WS, update_modified=False)",
      "",
      "    frappe.db.commit()",
      "    print('Workspace title set to slug:', SLUG_TITLE)",
      "    print('Workspace label set to:', VISIBLE_LABEL)",
      "    print('Customer users assigned:', ', '.join(users) if users else '(none)')",
      "PY",
      "docker cp /tmp/fix_customer_dashboard_slug_title.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_slug_title.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_fix_customer_dashboard_slug_title.run'",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend clear-cache && bench --site frontend clear-website-cache'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_slug_title.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_create_customer_dashboard_slug_alias.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_schema_safe.py'"
    ]
  }
}
