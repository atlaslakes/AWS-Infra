{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/fix_customer_dashboard_route_v2.py <<'PY'",
      "import frappe",
      "",
      "ROLE = 'Customer'",
      "TARGET_WS = 'Customer Dashboard'",
      "TARGET_ROUTE = 'customer-dashboard'",
      "FALLBACK_WS = 'Customer Self-Service'",
      "",
      "def resolve_workspace():",
      "    if frappe.db.exists('Workspace', TARGET_WS):",
      "        return TARGET_WS",
      "    if frappe.db.exists('Workspace', FALLBACK_WS):",
      "        return FALLBACK_WS",
      "    frappe.throw('No customer workspace found')",
      "",
      "def set_workspace_route(ws_name):",
      "    # Ensure route slug points to this workspace.",
      "    frappe.db.set_value('Workspace', ws_name, 'route', TARGET_ROUTE, update_modified=False)",
      "    frappe.db.set_value('Workspace', ws_name, 'title', TARGET_WS, update_modified=False)",
      "    frappe.db.set_value('Workspace', ws_name, 'label', TARGET_WS, update_modified=False)",
      "    frappe.db.set_value('Workspace', ws_name, 'public', 0, update_modified=False)",
      "    frappe.db.set_value('Workspace', ws_name, 'is_hidden', 0, update_modified=False)",
      "",
      "    # Role scope: customer only.",
      "    frappe.db.delete('Has Role', {'parenttype': 'Workspace', 'parent': ws_name})",
      "    frappe.get_doc({",
      "        'doctype': 'Has Role',",
      "        'parent': ws_name,",
      "        'parenttype': 'Workspace',",
      "        'parentfield': 'roles',",
      "        'role': ROLE",
      "    }).insert(ignore_permissions=True)",
      "",
      "def assign_customers(ws_name):",
      "    users = sorted(set([",
      "        r.get('parent')",
      "        for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})",
      "        if r.get('parent') and r.get('parent') != 'Guest'",
      "    ]))",
      "    for uid in users:",
      "        frappe.db.set_value('User', uid, 'default_workspace', ws_name, update_modified=False)",
      "    print('Customer users updated:', len(users))",
      "    for uid in users:",
      "        print('-', uid)",
      "",
      "def show_workspaces():",
      "    rows = frappe.get_all('Workspace', fields=['name', 'title', 'label', 'route'], limit_page_length=200)",
      "    print('Workspace route map (customer matches):')",
      "    for r in sorted(rows, key=lambda x: (x.get('name') or '').lower()):",
      "        text = ' '.join([(r.get('name') or ''), (r.get('title') or ''), (r.get('label') or ''), (r.get('route') or '')]).lower()",
      "        if 'customer' in text:",
      "            print(f\"- {r.get('name')} | title={r.get('title')} | label={r.get('label')} | route={r.get('route')}\")",
      "",
      "def run():",
      "    ws_name = resolve_workspace()",
      "    print('Using workspace:', ws_name)",
      "    set_workspace_route(ws_name)",
      "    assign_customers(ws_name)",
      "    frappe.db.commit()",
      "    show_workspaces()",
      "PY",
      "docker cp /tmp/fix_customer_dashboard_route_v2.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_route_v2.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_fix_customer_dashboard_route_v2.run'",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend clear-cache && bench --site frontend clear-website-cache'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_route_v2.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_dashboard_route.py'"
    ]
  }
}
