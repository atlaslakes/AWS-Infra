{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/fix_customer_desk_access.py <<'PY'",
      "import frappe",
      "",
      "ROLE = 'Customer'",
      "WORKSPACE = 'Customer Dashboard'",
      "MODULE_PROFILE = 'Customer Minimal Modules'",
      "",
      "def ensure_customer_role_desk_access():",
      "    if not frappe.db.exists('Role', ROLE):",
      "        frappe.throw('Customer role missing')",
      "    frappe.db.set_value('Role', ROLE, 'desk_access', 1, update_modified=False)",
      "    print('Role desk_access enabled:', ROLE)",
      "",
      "def update_customer_users():",
      "    users = sorted(set([",
      "        r.get('parent')",
      "        for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})",
      "        if r.get('parent') and r.get('parent') != 'Guest'",
      "    ]))",
      "",
      "    for uid in users:",
      "        user = frappe.get_doc('User', uid)",
      "        user.user_type = 'System User'",
      "        user.default_workspace = WORKSPACE",
      "        user.module_profile = MODULE_PROFILE",
      "        user.home_page = '/app/customer-dashboard'",
      "        user.save(ignore_permissions=True)",
      "        print(f'- updated {uid}: user_type={user.user_type}, default_workspace={user.default_workspace}, home_page={user.home_page}')",
      "",
      "def run():",
      "    ensure_customer_role_desk_access()",
      "    update_customer_users()",
      "    frappe.db.commit()",
      "    print('Done')",
      "PY",
      "docker cp /tmp/fix_customer_desk_access.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_desk_access.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_fix_customer_desk_access.run'",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend clear-cache && bench --site frontend clear-website-cache'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_fix_customer_desk_access.py'"
    ]
  }
}
