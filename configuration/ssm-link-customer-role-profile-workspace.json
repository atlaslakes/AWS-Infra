{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/link_customer_profile_workspace.py <<'PY'",
      "import frappe",
      "",
      "WORKSPACE = 'Customer Self-Service'",
      "ROLE = 'Customer'",
      "ROLE_PROFILE = 'Customer Role Profile'",
      "",
      "def ensure_role_profile():",
      "    if frappe.db.exists('Role Profile', ROLE_PROFILE):",
      "        rp = frappe.get_doc('Role Profile', ROLE_PROFILE)",
      "        print(f'Role Profile exists: {ROLE_PROFILE}')",
      "    else:",
      "        rp = frappe.get_doc({'doctype': 'Role Profile', 'role_profile': ROLE_PROFILE, 'roles': []})",
      "        rp.insert(ignore_permissions=True)",
      "        print(f'Role Profile created: {ROLE_PROFILE}')",
      "",
      "    if not any((r.role == ROLE) for r in (rp.roles or [])):",
      "        rp.append('roles', {'role': ROLE})",
      "        rp.save(ignore_permissions=True)",
      "        print(f'Added role {ROLE} to {ROLE_PROFILE}')",
      "    else:",
      "        print(f'Role {ROLE} already in {ROLE_PROFILE}')",
      "",
      "def ensure_workspace_role():",
      "    ws = frappe.get_doc('Workspace', WORKSPACE)",
      "    ws_roles = [r.role for r in (ws.roles or [])]",
      "    if ROLE not in ws_roles:",
      "        ws.append('roles', {'role': ROLE})",
      "        ws.save(ignore_permissions=True)",
      "        print(f'Linked workspace {WORKSPACE} to role {ROLE}')",
      "    else:",
      "        print(f'Workspace {WORKSPACE} already linked to role {ROLE}')",
      "",
      "def run():",
      "    ensure_role_profile()",
      "    ensure_workspace_role()",
      "    frappe.db.commit()",
      "    print('Verification:')",
      "    print('Role Profile exists:', bool(frappe.db.exists('Role Profile', ROLE_PROFILE)))",
      "    rp = frappe.get_doc('Role Profile', ROLE_PROFILE)",
      "    print('Customer in Role Profile:', any((r.role == ROLE) for r in (rp.roles or [])))",
      "    ws = frappe.get_doc('Workspace', WORKSPACE)",
      "    print('Customer linked to Workspace:', any((r.role == ROLE) for r in (ws.roles or [])))",
      "PY",
      "docker cp /tmp/link_customer_profile_workspace.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_link_customer_profile_workspace.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_link_customer_profile_workspace.run'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_link_customer_profile_workspace.py'"
    ]
  }
}
