{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/create_customer_dashboard_alias.py <<'PY'",
      "import frappe",
      "",
      "SOURCE_WS = 'Customer Self-Service'",
      "TARGET_WS = 'Customer Dashboard'",
      "ROLE = 'Customer'",
      "MODULE_PROFILE = 'Customer Dashboard Only'",
      "",
      "def clean_shortcut(row):",
      "    out = {}",
      "    for k in ['label', 'type', 'link_to', 'url', 'doc_view', 'stats_filter', 'color']:",
      "        v = row.get(k)",
      "        if v not in (None, ''):",
      "            out[k] = v",
      "    return out",
      "",
      "def clean_role(row):",
      "    return {'role': row.get('role')} if row.get('role') else None",
      "",
      "def ensure_target_workspace():",
      "    src = frappe.get_doc('Workspace', SOURCE_WS)",
      "    roles = [clean_role(r) for r in (src.roles or [])]",
      "    roles = [r for r in roles if r and r.get('role') == ROLE]",
      "    if not roles:",
      "        roles = [{'role': ROLE}]",
      "",
      "    shortcuts = [clean_shortcut(s) for s in (src.shortcuts or [])]",
      "",
      "    payload = {",
      "        'doctype': 'Workspace',",
      "        'name': TARGET_WS,",
      "        'title': TARGET_WS,",
      "        'label': TARGET_WS,",
      "        'module': src.module or 'Selling',",
      "        'public': 0,",
      "        'is_hidden': 0,",
      "        'icon': src.icon or 'users',",
      "        'indicator_color': src.indicator_color or 'blue',",
      "        'content': src.content or '[]',",
      "        'roles': roles,",
      "        'shortcuts': shortcuts,",
      "    }",
      "",
      "    if frappe.db.exists('Workspace', TARGET_WS):",
      "        ws = frappe.get_doc('Workspace', TARGET_WS)",
      "        for k in ['title', 'label', 'module', 'public', 'is_hidden', 'icon', 'indicator_color', 'content']:",
      "            setattr(ws, k, payload[k])",
      "        ws.roles = payload['roles']",
      "        ws.shortcuts = payload['shortcuts']",
      "        ws.save(ignore_permissions=True)",
      "        print('Workspace updated:', TARGET_WS)",
      "    else:",
      "        frappe.get_doc(payload).insert(ignore_permissions=True)",
      "        print('Workspace created:', TARGET_WS)",
      "",
      "def assign_customers():",
      "    customer_users = sorted(set([",
      "        r.get('parent')",
      "        for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})",
      "        if r.get('parent') and r.get('parent') != 'Guest'",
      "    ]))",
      "    for uid in customer_users:",
      "        frappe.db.set_value('User', uid, 'default_workspace', TARGET_WS, update_modified=False)",
      "        frappe.db.set_value('User', uid, 'module_profile', MODULE_PROFILE, update_modified=False)",
      "    print('Customer users assigned:', len(customer_users))",
      "    for uid in customer_users:",
      "        print(f'- {uid}')",
      "",
      "def run():",
      "    ensure_target_workspace()",
      "    assign_customers()",
      "    frappe.db.commit()",
      "    ws = frappe.get_doc('Workspace', TARGET_WS)",
      "    print('Verification workspace title:', ws.title)",
      "    print('Verification workspace public:', ws.public)",
      "PY",
      "docker cp /tmp/create_customer_dashboard_alias.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_create_customer_dashboard_alias.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_create_customer_dashboard_alias.run'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_create_customer_dashboard_alias.py'"
    ]
  }
}
