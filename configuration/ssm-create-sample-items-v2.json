{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/create_sample_items.py <<'PY'",
      "import frappe",
      "",
      "ITEM_GROUP = 'General Merchandise'",
      "UOM = 'Nos'",
      "ITEMS = [",
      "    ('CUST-1001', 'Customer Sample Item 1', 12.50),",
      "    ('CUST-1002', 'Customer Sample Item 2', 18.00),",
      "    ('CUST-1003', 'Customer Sample Item 3', 9.75),",
      "    ('CUST-1004', 'Customer Sample Item 4', 24.00),",
      "    ('CUST-1005', 'Customer Sample Item 5', 31.20),",
      "    ('CUST-1006', 'Customer Sample Item 6', 15.40),",
      "]",
      "",
      "def ensure_uom(name):",
      "    if not frappe.db.exists('UOM', name):",
      "        frappe.get_doc({'doctype': 'UOM', 'uom_name': name}).insert(ignore_permissions=True)",
      "        print('Created UOM:', name)",
      "",
      "def ensure_item_group(name):",
      "    if not frappe.db.exists('Item Group', name):",
      "        frappe.get_doc({",
      "            'doctype': 'Item Group',",
      "            'item_group_name': name,",
      "            'parent_item_group': 'All Item Groups',",
      "            'is_group': 0",
      "        }).insert(ignore_permissions=True)",
      "        print('Created Item Group:', name)",
      "",
      "def create_items():",
      "    created = 0",
      "    existed = 0",
      "    for code, name, price in ITEMS:",
      "        if frappe.db.exists('Item', code):",
      "            existed += 1",
      "            print('Exists:', code)",
      "            continue",
      "",
      "        doc = frappe.get_doc({",
      "            'doctype': 'Item',",
      "            'item_code': code,",
      "            'item_name': name,",
      "            'item_group': ITEM_GROUP,",
      "            'stock_uom': UOM,",
      "            'is_stock_item': 1,",
      "            'is_sales_item': 1,",
      "            'standard_rate': price",
      "        })",
      "        doc.insert(ignore_permissions=True)",
      "        created += 1",
      "        print('Created:', code)",
      "",
      "    print('Summary: created=', created, 'existed=', existed)",
      "",
      "def run():",
      "    ensure_uom(UOM)",
      "    ensure_item_group(ITEM_GROUP)",
      "    create_items()",
      "    frappe.db.commit()",
      "",
      "run()",
      "PY",
      "docker cp /tmp/create_sample_items.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_create_sample_items.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench set-config -g server_script_enabled 1; bench --site frontend execute frappe.custom_create_sample_items.run; rc=$?; bench set-config -g server_script_enabled 0; exit $rc'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_create_sample_items.py'"
    ]
  }
}
