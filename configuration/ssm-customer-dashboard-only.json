{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/customer_dashboard_only.py <<'PY'",
      "import frappe",
      "",
      "WS_NAME = 'Customer Self-Service'",
      "WS_LABEL = 'Customer Dashboard'",
      "ROLE = 'Customer'",
      "MODULE_PROFILE = 'Customer Dashboard Only'",
      "KEEP_MODULE = 'Selling'",
      "",
      "def ensure_workspace():",
      "    ws = frappe.get_doc('Workspace', WS_NAME)",
      "    ws.label = WS_LABEL",
      "    ws.title = WS_LABEL",
      "    ws.public = 0",
      "    ws.is_hidden = 0",
      "",
      "    # Keep workspace role-scoped to Customer only.",
      "    ws.roles = []",
      "    ws.append('roles', {'role': ROLE})",
      "    ws.save(ignore_permissions=True)",
      "    print(f'Workspace updated: {WS_NAME} -> label={WS_LABEL}, role={ROLE}, public=0')",
      "",
      "def ensure_module_profile():",
      "    if frappe.db.exists('Module Profile', MODULE_PROFILE):",
      "        mp = frappe.get_doc('Module Profile', MODULE_PROFILE)",
      "        print(f'Module Profile exists: {MODULE_PROFILE}')",
      "    else:",
      "        mp = frappe.get_doc({'doctype': 'Module Profile', 'module_profile_name': MODULE_PROFILE, 'block_modules': []})",
      "        mp.insert(ignore_permissions=True)",
      "        print(f'Module Profile created: {MODULE_PROFILE}')",
      "",
      "    all_modules = [m.get('name') for m in frappe.get_all('Module Def', fields=['name']) if m.get('name')]",
      "    blocked = sorted([m for m in all_modules if m != KEEP_MODULE])",
      "",
      "    mp.block_modules = []",
      "    for module_name in blocked:",
      "        mp.append('block_modules', {'module': module_name})",
      "    mp.save(ignore_permissions=True)",
      "    print(f'Module Profile updated: keeping only module {KEEP_MODULE}; blocked={len(blocked)}')",
      "",
      "def apply_to_customer_users():",
      "    customer_user_ids = [r.get('parent') for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})]",
      "    customer_user_ids = sorted(set([u for u in customer_user_ids if u and u != 'Guest']))",
      "",
      "    for uid in customer_user_ids:",
      "        user = frappe.get_doc('User', uid)",
      "        user.default_workspace = WS_NAME",
      "        user.module_profile = MODULE_PROFILE",
      "        user.save(ignore_permissions=True)",
      "",
      "    print('Customer users updated:', len(customer_user_ids))",
      "    for uid in customer_user_ids:",
      "        print(f'- {uid}')",
      "",
      "def run():",
      "    ensure_workspace()",
      "    ensure_module_profile()",
      "    apply_to_customer_users()",
      "    frappe.db.commit()",
      "",
      "    # Verification",
      "    ws = frappe.get_doc('Workspace', WS_NAME)",
      "    ws_roles = [r.role for r in (ws.roles or [])]",
      "    print('Verification workspace label:', ws.label)",
      "    print('Verification workspace public:', ws.public)",
      "    print('Verification workspace roles:', ', '.join(ws_roles) if ws_roles else '(none)')",
      "PY",
      "docker cp /tmp/customer_dashboard_only.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_customer_dashboard_only.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_customer_dashboard_only.run'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_customer_dashboard_only.py'"
    ]
  }
}
