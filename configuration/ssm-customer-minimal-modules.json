{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/customer_minimal_modules.py <<'PY'",
      "import json",
      "import frappe",
      "",
      "ROLE = 'Customer'",
      "MODULE_PROFILE = 'Customer Minimal Modules'",
      "WORKSPACE = 'Customer Dashboard'",
      "KEEP_MODULES = {'Selling', 'Accounts'}",
      "",
      "def ensure_workspace():",
      "    if not frappe.db.exists('Workspace', WORKSPACE):",
      "        frappe.throw(f'Workspace not found: {WORKSPACE}')",
      "",
      "    ws = frappe.get_doc('Workspace', WORKSPACE)",
      "    ws.label = WORKSPACE",
      "    ws.title = WORKSPACE",
      "    ws.public = 0",
      "    ws.is_hidden = 0",
      "",
      "    ws.content = json.dumps([",
      "        {'id': 'h1', 'type': 'header', 'data': {'text': 'Customer Dashboard'}},",
      "        {'id': 'p1', 'type': 'paragraph', 'data': {'text': 'Place orders, track order status, and view invoices.'}},",
      "        {'id': 's1', 'type': 'shortcut', 'data': {'shortcut_name': 'Place Order'}},",
      "        {'id': 's2', 'type': 'shortcut', 'data': {'shortcut_name': 'Track My Orders'}},",
      "        {'id': 's3', 'type': 'shortcut', 'data': {'shortcut_name': 'My Invoices'}}",
      "    ])",
      "",
      "    ws.shortcuts = []",
      "    ws.append('shortcuts', {'label': 'Place Order', 'type': 'DocType', 'link_to': 'Sales Order', 'doc_view': 'New', 'color': 'blue'})",
      "    ws.append('shortcuts', {'label': 'Track My Orders', 'type': 'DocType', 'link_to': 'Sales Order', 'doc_view': 'List', 'color': 'green'})",
      "    ws.append('shortcuts', {'label': 'My Invoices', 'type': 'DocType', 'link_to': 'Sales Invoice', 'doc_view': 'List', 'color': 'purple'})",
      "",
      "    ws.roles = []",
      "    ws.append('roles', {'role': ROLE})",
      "    ws.save(ignore_permissions=True)",
      "    print('Workspace set to 3 shortcuts only')",
      "",
      "def ensure_module_profile():",
      "    if not frappe.db.exists('Module Profile', MODULE_PROFILE):",
      "        frappe.get_doc({'doctype': 'Module Profile', 'module_profile_name': MODULE_PROFILE}).insert(ignore_permissions=True)",
      "        print('Module Profile created:', MODULE_PROFILE)",
      "    else:",
      "        print('Module Profile exists:', MODULE_PROFILE)",
      "",
      "    frappe.db.delete('Block Module', {'parenttype': 'Module Profile', 'parent': MODULE_PROFILE})",
      "    all_modules = sorted([m.get('name') for m in frappe.get_all('Module Def', fields=['name']) if m.get('name')])",
      "    blocked = [m for m in all_modules if m not in KEEP_MODULES]",
      "    for module_name in blocked:",
      "        frappe.get_doc({",
      "            'doctype': 'Block Module',",
      "            'parent': MODULE_PROFILE,",
      "            'parenttype': 'Module Profile',",
      "            'parentfield': 'block_modules',",
      "            'module': module_name",
      "        }).insert(ignore_permissions=True)",
      "",
      "    print('Modules kept:', ', '.join(sorted(KEEP_MODULES)))",
      "    print('Modules blocked:', len(blocked))",
      "",
      "def apply_to_customer_users():",
      "    customer_users = sorted(set([",
      "        r.get('parent')",
      "        for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})",
      "        if r.get('parent') and r.get('parent') != 'Guest'",
      "    ]))",
      "",
      "    for uid in customer_users:",
      "        role_rows = frappe.get_all('Has Role', fields=['name', 'role'], filters={'parenttype': 'User', 'parent': uid})",
      "        removed = 0",
      "        for row in role_rows:",
      "            if row.get('role') != ROLE:",
      "                frappe.db.delete('Has Role', {'name': row.get('name')})",
      "                removed += 1",
      "",
      "        if not frappe.db.exists('Has Role', {'parenttype': 'User', 'parent': uid, 'role': ROLE}):",
      "            frappe.get_doc({'doctype': 'Has Role', 'parent': uid, 'parenttype': 'User', 'parentfield': 'roles', 'role': ROLE}).insert(ignore_permissions=True)",
      "",
      "        frappe.db.set_value('User', uid, 'default_workspace', WORKSPACE, update_modified=False)",
      "        frappe.db.set_value('User', uid, 'module_profile', MODULE_PROFILE, update_modified=False)",
      "        print(f'- {uid}: removed_roles={removed}')",
      "",
      "    print('Customer users updated:', len(customer_users))",
      "",
      "def run():",
      "    ensure_workspace()",
      "    ensure_module_profile()",
      "    apply_to_customer_users()",
      "    frappe.db.commit()",
      "    print('Done')",
      "PY",
      "docker cp /tmp/customer_minimal_modules.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_customer_minimal_modules.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_customer_minimal_modules.run'",
      "docker exec frappe_docker-backend-1 bash -lc 'bench --site frontend clear-cache && bench --site frontend clear-website-cache'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_customer_minimal_modules.py'"
    ]
  }
}
