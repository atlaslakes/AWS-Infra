{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/find_user_and_fix_landing.py <<'PY'",
      "import frappe",
      "",
      "ROLE_PROFILE = 'Customer Role Profile'",
      "WORKSPACE = 'Customer Self-Service'",
      "",
      "def pick_user():",
      "    rows = frappe.get_all('User', fields=['name', 'full_name', 'user_type', 'enabled'], filters={'enabled': 1})",
      "    for r in rows:",
      "        fn = (r.get('full_name') or '').lower()",
      "        nm = (r.get('name') or '').lower()",
      "        if 'aizen' in fn or 'aizen' in nm:",
      "            return r, rows",
      "    return None, rows",
      "",
      "def run():",
      "    user_row, rows = pick_user()",
      "    print('Enabled users count:', len(rows))",
      "    if not user_row:",
      "        print('No user matching aizen found. First 20 users:')",
      "        for r in rows[:20]:",
      "            print(f\"- {r['name']} | {r.get('full_name')} | {r.get('user_type')}\")",
      "        return",
      "",
      "    user_id = user_row['name']",
      "    print('Matched user:', user_id, '|', user_row.get('full_name'))",
      "    user = frappe.get_doc('User', user_id)",
      "    print('Current user_type:', user.user_type)",
      "",
      "    # Ensure role profile is assigned.",
      "    user.role_profile_name = ROLE_PROFILE",
      "    # Default workspace applies in Desk; harmless for website users.",
      "    user.default_workspace = WORKSPACE",
      "    user.save(ignore_permissions=True)",
      "    frappe.db.commit()",
      "",
      "    user = frappe.get_doc('User', user_id)",
      "    roles = [r.role for r in (user.roles or [])]",
      "    print('After update role_profile_name:', user.role_profile_name)",
      "    print('After update default_workspace:', user.default_workspace)",
      "    print('Roles:', ', '.join(sorted(roles)))",
      "    print('User Type:', user.user_type)",
      "PY",
      "docker cp /tmp/find_user_and_fix_landing.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_find_user_and_fix_landing.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_find_user_and_fix_landing.run'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_find_user_and_fix_landing.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_check_customer_user_view.py'"
    ]
  }
}
