{
  "DocumentName": "AWS-RunShellScript",
  "InstanceIds": ["i-0be6845d8493d077a"],
  "Parameters": {
    "commands": [
      "set -e",
      "cat > /tmp/customer_dashboard_only_v2.py <<'PY'",
      "import frappe",
      "",
      "WS_NAME = 'Customer Self-Service'",
      "WS_LABEL = 'Customer Dashboard'",
      "ROLE = 'Customer'",
      "MODULE_PROFILE = 'Customer Dashboard Only'",
      "",
      "def ensure_workspace():",
      "    ws = frappe.get_doc('Workspace', WS_NAME)",
      "    ws.label = WS_LABEL",
      "    ws.title = WS_LABEL",
      "    ws.public = 0",
      "    ws.is_hidden = 0",
      "    ws.roles = []",
      "    ws.append('roles', {'role': ROLE})",
      "    ws.save(ignore_permissions=True)",
      "    print(f'Workspace set: {WS_NAME} label={WS_LABEL} role={ROLE} public=0')",
      "",
      "def ensure_customer_role_only_for_customer_users():",
      "    customer_users = sorted(set([",
      "        r.get('parent')",
      "        for r in frappe.get_all('Has Role', fields=['parent'], filters={'parenttype': 'User', 'role': ROLE})",
      "        if r.get('parent') and r.get('parent') != 'Guest'",
      "    ]))",
      "",
      "    print('Customer users found:', len(customer_users))",
      "    for uid in customer_users:",
      "        # Remove all non-customer roles for strict dashboard visibility.",
      "        non_customer_rows = frappe.get_all('Has Role', fields=['name', 'role'], filters={'parenttype': 'User', 'parent': uid})",
      "        removed = 0",
      "        for row in non_customer_rows:",
      "            if row.get('role') != ROLE:",
      "                frappe.db.delete('Has Role', {'name': row.get('name')})",
      "                removed += 1",
      "",
      "        # Ensure Customer role exists after cleanup.",
        "        if not frappe.db.exists('Has Role', {'parenttype': 'User', 'parent': uid, 'role': ROLE}):",
        "            frappe.get_doc({'doctype': 'Has Role', 'parent': uid, 'parenttype': 'User', 'parentfield': 'roles', 'role': ROLE}).insert(ignore_permissions=True)",
      "",
      "        # Set landing and module profile directly.",
      "        frappe.db.set_value('User', uid, 'default_workspace', WS_NAME, update_modified=False)",
      "        frappe.db.set_value('User', uid, 'module_profile', MODULE_PROFILE, update_modified=False)",
      "        print(f'- {uid}: removed_roles={removed}, default_workspace={WS_NAME}, module_profile={MODULE_PROFILE}')",
      "",
      "def run():",
      "    ensure_workspace()",
      "    ensure_customer_role_only_for_customer_users()",
      "    frappe.db.commit()",
      "",
      "    ws = frappe.get_doc('Workspace', WS_NAME)",
      "    ws_roles = [r.role for r in (ws.roles or [])]",
      "    print('Verification workspace label:', ws.label)",
      "    print('Verification workspace roles:', ', '.join(ws_roles) if ws_roles else '(none)')",
      "PY",
      "docker cp /tmp/customer_dashboard_only_v2.py frappe_docker-backend-1:/home/frappe/frappe-bench/apps/frappe/frappe/custom_customer_dashboard_only_v2.py",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'bench --site frontend execute frappe.custom_customer_dashboard_only_v2.run'",
      "docker exec -w /home/frappe/frappe-bench frappe_docker-backend-1 bash -lc 'rm -f /home/frappe/frappe-bench/apps/frappe/frappe/custom_customer_dashboard_only_v2.py /home/frappe/frappe-bench/apps/frappe/frappe/custom_customer_dashboard_only.py'"
    ]
  }
}
